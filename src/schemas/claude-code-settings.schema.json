{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "claude-code-settings",
  "title": "Claude Code settings",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "apiKeyHelper": { "type": "string" },
    "model": { "type": "string" },
    "theme": {
      "type": "string",
      "enum": ["dark", "light", "dark-daltonized", "light-daltonized"]
    },
    "outputStyle": { "type": "string" },
    "telemetry": { "type": "object" },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } },
        "ask": { "type": "array", "items": { "type": "string" } },
        "additionalDirectories": { "type": "array", "items": { "type": "string" } },
        "defaultMode": {
          "type": "string",
          "enum": ["acceptEdits", "auto", "bypassPermissions", "default", "plan"]
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "hooks": { "type": "object" },
    "statusLine": { "type": ["object", "string"] },
    "includeCoAuthoredBy": { "type": "boolean" },
    "cleanupPeriodDays": { "type": "integer", "minimum": 0 },
    "enabledPlugins": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "feedbackSurveyState": { "type": "object" },
    "extraKnownMcpServers": { "type": "object" }
  }
}
