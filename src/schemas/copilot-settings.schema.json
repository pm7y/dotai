{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "copilot-settings",
  "title": "Copilot CLI settings",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "model": { "type": "string" },
    "telemetry": { "type": "boolean" },
    "trusted_folders": {
      "type": "array",
      "items": { "type": "string" }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
